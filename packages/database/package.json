{
  "name": "@repo/database",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "DATABASE_URL=\"${DATABASE_URL:-postgresql://placeholder:placeholder@localhost:5432/placeholder}\" prisma generate && tsc && cp -r src/postgres/migrations/*.sql dist/postgres/migrations/",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "postinstall": "DATABASE_URL=\"${DATABASE_URL:-postgresql://placeholder:placeholder@localhost:5432/placeholder}\" prisma generate",
    "migrate": "tsx scripts/run-migration.ts",
    "schema-request": "tsx scripts/schema-request.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "~5.22.0",
    "@repo/shared": "workspace:*",
    "ai": "^6.0.176",
    "mongodb": "^7.2.0",
    "pg": "^8.20.0",
    "prisma": "~5.22.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.40",
    "@types/pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}
