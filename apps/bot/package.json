{
  "name": "bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prebuild": "pnpm --filter @repo/shared --filter @repo/database --filter @repo/agent build && node scripts/generate-deployment-info.js",
    "build": "tsc && npm run copy-assets",
    "copy-assets": "mkdir -p dist/public && cp -r public/* dist/public/ && cp omega-manifest.json dist/",
    "pretype-check": "pnpm --filter @repo/shared --filter @repo/database --filter @repo/agent build",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.63",
    "@google/generative-ai": "^0.21.0",
    "@octokit/rest": "^21.0.0",
    "@repo/agent": "workspace:*",
    "@repo/database": "workspace:*",
    "@repo/shared": "workspace:*",
    "@slidev/cli": "^0.50.0",
    "ai": "^6.0.176",
    "discord-api-types": "^0.38.35",
    "discord.js": "^14.26.4",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "fish-joke-generator": "^1.1.0",
    "lib0": "^0.2.114",
    "mime": "^4.0.0",
    "minimatch": "^10.2.5",
    "minisearch": "^7.2.0",
    "node-cron": "^3.0.3",
    "openai": "^4.104.0",
    "playwright-chromium": "^1.59.1",
    "pusher": "^5.3.3",
    "twitter-api-v2": "^1.29.0",
    "undici": "^7.25.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.18",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}
